      "desktop": "render(() => {\nconst [open, setOpen] = React.useState(false);\nconst handleModalOpen = () => setOpen(!open);\n\nreturn (\n<>\n<Button\nsize={56}\nonClick={handleModalOpen}\nblock={isMobile()}\nbreakpoint={BREAKPOINT}\n>\nПоказать BaseModal\n</Button>\n\n<BaseModal open={open} onClose={handleModalOpen}>\n<div style={{ padding: '100px' }}>BaseModal</div>\n</BaseModal>\n</>\n);\n});",
