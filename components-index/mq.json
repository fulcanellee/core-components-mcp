{
  "componentName": "Mq",
  "packageName": "mq",
  "description": "Используется для имплементации поддержки медиа запросов.",
  "imports": [
    {
      "from": "@alfalab/core-components/mq",
      "named": [
        "Mq",
        "useMatchMedia"
      ]
    }
  ],
  "props": {
    "query": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Media выражение или кастомный запрос из `mq.json`, например `--mobile`."
    },
    "touch": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Запрос на поддержку тач-событий"
    },
    "defaultMatchMediaValue": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Значение по-умолчанию для хука useMatchMedia"
    },
    "children": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Дочерние элементы."
    },
    "onMatchChange": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Обработчик изменений в совпадении запросов"
    }
  },
  "examples": [
    {
      "title": "Пример",
      "description": "В этом примере при изменении ширины окна браузера кнопка будет переключаться между мобильной и десктопной версией.",
      "desktop": "<div>\n<Mq query='--mobile'>\n<Button breakpoint={BREAKPOINT} >Мобильная кнопка</Button>\n</Mq>\n<Mq query='--tablet-s'>\n<Button breakpoint={BREAKPOINT} >Десктопная кнопка</Button>\n</Mq>\n</div>",
      "mobile": null
    }
  ]
}