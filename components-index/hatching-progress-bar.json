{
  "componentName": "HatchingProgressBar",
  "packageName": "hatching-progress-bar",
  "props": {
    "value": {
      "type": "number",
      "required": true,
      "defaultValue": null,
      "description": "Значение заполненной части 0-100"
    },
    "hatchValue": {
      "type": "number",
      "required": true,
      "defaultValue": null,
      "description": "Значение будущей заполненной части 0-100"
    },
    "className": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Css-класс для стилизации"
    },
    "view": {
      "type": "enum",
      "required": false,
      "defaultValue": "positive",
      "description": "Цвет заполнения"
    },
    "dataTestId": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Id компонента для тестов"
    }
  }
}