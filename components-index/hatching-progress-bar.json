{
  "componentName": "HatchingProgressBar",
  "packageName": "hatching-progress-bar",
  "description": "Используется для отображения прогресса при заполнении формы.",
  "imports": [
    {
      "from": "@alfalab/core-components/hatching-progress-bar",
      "named": [
        "HatchingProgressBar"
      ]
    }
  ],
  "props": {
    "value": {
      "type": "number",
      "required": true,
      "defaultValue": null,
      "description": "Значение заполненной части 0-100"
    },
    "hatchValue": {
      "type": "number",
      "required": true,
      "defaultValue": null,
      "description": "Значение будущей заполненной части 0-100"
    },
    "className": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Css-класс для стилизации"
    },
    "view": {
      "type": "enum",
      "required": false,
      "defaultValue": "positive",
      "description": "Цвет заполнения"
    },
    "dataTestId": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Id компонента для тестов"
    }
  },
  "examples": [
    {
      "title": "Пример",
      "description": "Заливкой обозначается текущий прогресс. \nШтриховкой обозначается прогресс, который будет достигнут при выполнении какого-либо условия.",
      "desktop": "<HatchingProgressBar value={40} hatchValue={60} />",
      "mobile": null
    }
  ]
}