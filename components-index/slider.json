{
  "componentName": "Slider",
  "packageName": "slider",
  "props": {
    "min": {
      "type": "enum",
      "required": false,
      "defaultValue": "0",
      "description": "Мин. допустимое число"
    },
    "max": {
      "type": "enum",
      "required": false,
      "defaultValue": "100",
      "description": "Макс. допустимое число"
    },
    "step": {
      "type": "enum",
      "required": false,
      "defaultValue": "1",
      "description": "Шаг (должен нацело делить отрезок между мин и макс)"
    },
    "pips": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Отображение подписей\nhttps://refreshless.com/nouislider/pips/"
    },
    "range": {
      "type": "enum",
      "required": false,
      "defaultValue": "{ min, max }",
      "description": "Настройка шагов\nhttps://refreshless.com/nouislider/pips/#section-range"
    },
    "snap": {
      "type": "enum",
      "required": false,
      "defaultValue": "false",
      "description": "Флаг точной привязки к range\nhttps://refreshless.com/nouislider/examples/#section-skipping"
    },
    "value": {
      "type": "enum",
      "required": false,
      "defaultValue": "0",
      "description": "Значение слайдера"
    },
    "valueTo": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Второе значение слайдера (значение второго ползунка)\nесли передать ValueTo, то слайдер будет работать как range"
    },
    "disabled": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Заблокированное состояние"
    },
    "className": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Дополнительный класс"
    },
    "behaviour": {
      "type": "enum",
      "required": false,
      "defaultValue": "tap",
      "description": "Поведение ползунка"
    },
    "size": {
      "type": "enum",
      "required": false,
      "defaultValue": "2",
      "description": "Размер"
    },
    "onChange": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Обработчик поля ввода"
    },
    "onStart": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "@deprecated Обработчик начала перетаскивания ползунка"
    },
    "onEnd": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Обработчик окончания перетаскивания ползунка\n@description https://refreshless.com/nouislider/events-callbacks/#section-change"
    },
    "dataTestId": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Идентификатор для систем автоматизированного тестирования"
    }
  }
}