{
  "componentName": "FileUploadItemV1",
  "packageName": "file-upload-item-v1",
  "description": "Используется для отображения загружаемого файла.",
  "imports": [
    {
      "from": "@alfalab/core-components/file-upload-item-v1",
      "named": [
        "FileUploadItemV1"
      ]
    }
  ],
  "props": {
    "className": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Дополнительный класс"
    },
    "id": {
      "type": "enum",
      "required": false,
      "defaultValue": "0",
      "description": "Идентификатор элемента"
    },
    "name": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Имя файла с расширением"
    },
    "size": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Размер файла"
    },
    "uploadDate": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Дата загрузки файла"
    },
    "downloadLink": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Ссылка на файл. Если прокидывается этот параметр, то появляется кнопка скачивания"
    },
    "download": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Рекомендует браузеру скачивать контент по ссылке.\nВ проп может быть передано рекомендуемое название скачиваемого файла."
    },
    "showDelete": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Отображение кнопки удаления"
    },
    "showRestore": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Отображение кнопки восстановления"
    },
    "uploadPercent": {
      "type": "enum",
      "required": false,
      "defaultValue": "0",
      "description": "Процент загрузки файла"
    },
    "uploadStatus": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Статус загрузки файла"
    },
    "error": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Сообщение об ошибке"
    },
    "children": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Дочерние элементы"
    },
    "icon": {
      "type": "enum",
      "required": false,
      "defaultValue": "fileIcon(name)",
      "description": "Компонент кастомной иконки"
    },
    "onDownload": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Обработчик загрузки файла"
    },
    "onDelete": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Обработчик удаления файла"
    },
    "onRestore": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Обработчик восстановления файла"
    },
    "disableButtons": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Управление активностью кнопок"
    },
    "multiline": {
      "type": "enum",
      "required": false,
      "defaultValue": "false",
      "description": "Разрешить многострочное название файла"
    },
    "target": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Указывает, где открыть скачиваемый документ"
    },
    "dataTestId": {
      "type": "enum",
      "required": false,
      "defaultValue": null,
      "description": "Идентификатор для систем автоматизированного тестирования"
    }
  },
  "examples": [
    {
      "title": "Примеры",
      "description": "",
      "desktop": "<>\n<FileUploadItemV1\nname='Довольно длинное название файла.pdf'\nuploadDate='22.01.2018'\nsize={500000000}\nshowDelete={false}\nshowRestore={true}\n/>\n<FileUploadItemV1\nname='Название файла.pdf'\nuploadDate='22.01.2018'\nsize={45000}\nshowDelete={true}\n/>\n<FileUploadItemV1\nname='С кастомной иконкой.pdf'\nuploadDate='22.01.2018'\nsize={50000}\nshowDelete={true}\nicon={DiamondsMIcon}\n/>\n<FileUploadItemV1\nname='Название файла.pdf'\nuploadDate='22.01.2018'\nuploadPercent={23.5678}\nuploadStatus='UPLOADING'\nshowDelete={true}\n/>\n<FileUploadItemV1\nname='Название файла.txt'\nuploadDate='22.01.2018'\nsize={157290000}\ndownloadLink='/link'\nuploadStatus='SUCCESS'\nshowDelete={true}\n/>\n<FileUploadItemV1\nname='Название файла.jpg'\nuploadDate='22.01.2018'\nsize={45000}\nuploadStatus='ERROR'\nshowDelete={true}\n/>\n<FileUploadItemV1\nname='Название файла.png'\nuploadDate='22.01.2018'\nsize={450000000}\nuploadStatus='ERROR'\nerror={\n<>\n<p style={{ margin: 0, marginBottom: '8px' }}>Размер больше 500 Кб</p>\n<p style={{ margin: 0 }}>\nНедопустимый формат файла. Загрузите файл в одном из этих форматов: .txt, .xml,\n.csv\n</p>\n</>\n}\nshowDelete={true}\n/>\n</>",
      "mobile": null
    }
  ]
}