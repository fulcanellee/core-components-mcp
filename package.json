{
  "name": "core-components-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal MCP server built with the official TypeScript SDK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
