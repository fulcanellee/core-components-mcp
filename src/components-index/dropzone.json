    "Overlay": {
      "type": "ComponentType<OverlayProps>",
      "typeName": "enum",
      "rawType": "ComponentType<OverlayProps>",
      "enumValues": [
        "ComponentClass<OverlayProps, any>",
        "FunctionComponent<OverlayProps>"
