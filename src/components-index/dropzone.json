      "typeName": "enum",
      "rawType": "string",
      "enumValues": [
        "string"
      ],
      "required": false,
      "defaultValue": null,
      "description": "Дополнительный класс для контента"
    },
    "text": {
      "type": "string",
      "typeName": "enum",
      "rawType": "string",
      "enumValues": [
        "string"
      ],
      "required": false,
      "defaultValue": "Перетащите файлы",
      "description": "Подпись для заглушки"
    },
    "disabled": {
      "type": "boolean",
      "typeName": "enum",
      "rawType": "boolean",
      "enumValues": [
        "false",
        "true"
      ],
      "required": false,
      "defaultValue": null,
      "description": "Заблокированное состояние"
    },
    "error": {
      "type": "boolean",
      "typeName": "enum",
      "rawType": "boolean",
      "enumValues": [
        "false",
        "true"
      ],
      "required": false,
      "defaultValue": "false",
      "description": "Состояние ошибки"
    },
    "block": {
      "type": "boolean",
      "typeName": "enum",
      "rawType": "boolean",
      "enumValues": [
        "false",
