{
  "componentName": "Dropzone",
  "packageName": "dropzone",
  "description": "Используется для прикрепления файлов.",
  "imports": [
    {
      "from": "@alfalab/core-components/dropzone",
      "named": [
        "Dropzone"
      ]
    }
  ],
  "props": {
    "className": {
      "type": "string",
