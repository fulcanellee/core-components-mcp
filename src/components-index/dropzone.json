      "type": "((event: DragEvent<HTMLElement>) => void)",
      "typeName": "enum",
      "rawType": "((event: DragEvent<HTMLElement>) => void)",
      "enumValues": [
        "(event: DragEvent<HTMLElement>) => void"
      ],
      "required": false,
      "defaultValue": null,
