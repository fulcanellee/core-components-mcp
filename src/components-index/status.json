{
  "componentName": "Status",
  "packageName": "status",
  "description": "Используется для цветового кодирования статусов.",
  "imports": [
    {
      "from": "@alfalab/core-components/status",
      "named": [
        "Status"
      ]
    }
  ],
  "props": {
    "className": {
      "type": "string",
      "typeName": "enum",
      "rawType": "string",
      "enumValues": [
        "string"
      ],
      "required": false,
      "defaultValue": null,
      "description": "Дополнительный класс"
    },
    "view": {
      "type": "\"contrast\" | \"soft\" | \"muted\" | \"muted-alt\"",
      "typeName": "enum",
      "rawType": "\"contrast\" | \"soft\" | \"muted\" | \"muted-alt\"",
      "enumValues": [
        "\"contrast\"",
        "\"soft\"",
        "\"muted\"",
        "\"muted-alt\""
      ],
      "required": false,
      "defaultValue": "muted-alt",
      "description": "Вид компонента\n@description soft deprecated, используйте вместо него muted-alt"
    },
    "color": {
      "type": "\"green\" | \"orange\" | \"red\" | \"blue\" | \"grey\" | \"teal\" | \"purple\"",
      "typeName": "enum",
      "rawType": "\"green\" | \"orange\" | \"red\" | \"blue\" | \"grey\" | \"teal\" | \"purple\"",
      "enumValues": [
        "\"green\"",
        "\"orange\"",
        "\"red\"",
        "\"blue\"",
        "\"grey\"",
        "\"teal\"",
        "\"purple\""
      ],
      "required": false,
      "defaultValue": "green",
      "description": "Цветовое оформление компонента"
    },
    "dataTestId": {
      "type": "string",
      "typeName": "enum",
      "rawType": "string",
      "enumValues": [
        "string"
      ],
      "required": false,
      "defaultValue": null,
      "description": "Идентификатор для систем автоматизированного тестирования"
    },
    "children": {
      "type": "ReactNode",
      "typeName": "enum",
      "rawType": "ReactNode",
      "enumValues": [
        "null",
        "string",
        "number",
        "false",
        "true",
        "ReactElement<any, string | JSXElementConstructor<any>>",
        "Iterable<ReactNode>",
        "ReactPortal"
      ],
      "required": false,
      "defaultValue": null,
      "description": "Дочерние элементы."
    },
    "size": {
      "type": "40 | 24 | 32 | 20",
      "typeName": "enum",
      "rawType": "40 | 24 | 32 | 20",
      "enumValues": [
        "40",
        "24",
        "32",
        "20"
      ],
      "required": false,
      "defaultValue": "20",
      "description": "Размер компонента"
    },
    "shape": {
      "type": "\"rounded\" | \"rectangular\"",
      "typeName": "enum",
      "rawType": "\"rounded\" | \"rectangular\"",
      "enumValues": [
        "\"rounded\"",
        "\"rectangular\""
      ],
      "required": false,
      "defaultValue": "rectangular",
      "description": "Форма компонента"
    },
    "uppercase": {
      "type": "boolean",
      "typeName": "enum",
      "rawType": "boolean",
      "enumValues": [
        "false",
        "true"
      ],
      "required": false,
      "defaultValue": "true",
      "description": "Текст компонента в верхнем регистре"
    },
    "leftAddons": {
      "type": "ReactNode",
      "typeName": "enum",
      "rawType": "ReactNode",
      "enumValues": [
        "null",
        "string",
        "number",
        "false",
        "true",
        "ReactElement<any, string | JSXElementConstructor<any>>",
        "Iterable<ReactNode>",
        "ReactPortal"
      ],
      "required": false,
      "defaultValue": null,
      "description": "Слот слева"
    }
  },
  "examples": [
    {
      "title": "Размеры",
      "description": "Кнопка доступна в размерах 40, 32, 24, 20.",
      "desktop": "<Container>\n<div style={{ display: 'flex' }}>\n<Status size='40' uppercase={false}>\nВсё в порядке\n</Status>\n<Gap size={12} direction='horizontal' />\n<Status size='32' uppercase={false}>\nВсё в порядке\n</Status>\n<Gap size={12} direction='horizontal' />\n<Status size='24' uppercase={false}>\nВсё в порядке\n</Status>\n<Gap size={12} direction='horizontal' />\n<Status size='20' uppercase={false}>\nВсё в порядке\n</Status>\n</div>\n</Container>",
      "mobile": null
    },
    {
      "title": "Форма",
      "description": "Для статуса доступно два варианта скругления углов.",
      "desktop": "<Container>\n<div style={{ display: 'flex' }}>\n<Status size='40' uppercase={false}>\nВсё в порядке\n</Status>\n<Gap size={12} direction='horizontal' />\n<Status size='40' uppercase={false} shape='rounded'>\nВсё в порядке\n</Status>\n</div>\n</Container>",
      "mobile": null
    },
    {
      "title": "Стиль лейбла",
      "description": "Для лейбла можно включить опцию `uppercase`.",
      "desktop": "<Container>\n<div style={{ display: 'flex' }}>\n<Status size='40' uppercase={false}>\nВсё в порядке\n</Status>\n<Gap size={12} direction='horizontal' />\n<Status size='40'>Всё в порядке</Status>\n</div>\n</Container>",
      "mobile": null
    },
    {
      "title": "Аддон",
      "description": "В левый аддон можно передать иконку или другой контент.",
      "desktop": "render(() => {\nreturn (\n<Space direction='horizontal' size={12}>\n<Status view='muted' size={40} uppercase={false}>\nБез аддона\n</Status>\n<Status\nview='muted'\nsize={40}\nuppercase={false}\nleftAddons={<DiamondsMIcon width={16} height={16} />}\n>\nС аддоном\n</Status>\n</Space>\n);\n});",
      "mobile": null
    },
    {
      "title": "Цвета",
      "description": "",
      "desktop": "<Container>\n<div style={{ display: 'flex' }}>\n<div style={{ display: 'flex', flexDirection: 'column' }}>\n{COLORS.map((color) => (\n<React.Fragment key={color}>\n<Status view='contrast' color={color} key={color} size='24' uppercase={false}>\nLabel\n</Status>\n<Gap size={12} />\n</React.Fragment>\n))}\n</div>\n<Gap size={12} direction='horizontal' />\n<div style={{ display: 'flex', flexDirection: 'column' }}>\n{COLORS.map((color) => (\n<React.Fragment key={color}>\n<Status view='muted-alt' color={color} key={color} size='24' uppercase={false}>\nLabel\n</Status>\n<Gap size={12} />\n</React.Fragment>\n))}\n</div>\n<Gap size={12} direction='horizontal' />\n<div style={{ display: 'flex', flexDirection: 'column' }}>\n{COLORS.map((color) => (\n<React.Fragment key={color}>\n<Status view='muted' color={color} size='24' uppercase={false}>\nLabel\n</Status>\n<Gap size={12} />\n</React.Fragment>\n))}\n</div>\n</div>\n</Container>",
      "mobile": null
    },
    {
      "title": "Кастомизация",
      "description": "Статусу можно задать кастомный цвет текста и фона.",
      "desktop": "render(() => {\nreturn (\n<Container>\n<style>\n{\n'.className.className {color: var(--color-light-decorative-text-purple); background-color: var(--color-light-decorative-muted-purple);}'\n}\n</style>\n<Status size={40} uppercase={false} className='className'>\nКастом\n</Status>\n</Container>\n);\n});",
      "mobile": null
    }
  ]
}