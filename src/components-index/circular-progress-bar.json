  "examples": [
    {
      "title": "Примеры",
      "description": "Доступны 144, 128, 96, 80, 64, 48, 24 и произвольный размер компонента.",
      "desktop": "<Container align={isMobile() ? 'center' : 'left'}>\n<Space direction={isMobile() ? 'vertical' : 'horizontal'} align='center' size={24}>\n<CircularProgressBar value={25} size={144} contentColor='primary' />\n<CircularProgressBar value={25} size={128} contentColor='primary' />\n<CircularProgressBar value={25} size={96} contentColor='primary' />\n<CircularProgressBar value={25} size={80} contentColor='primary' />\n<CircularProgressBar value={25} size={64} contentColor='primary' />\n<CircularProgressBar value={25} size={48} contentColor='primary' />\n<CircularProgressBar value={25} size={24} contentColor='primary' />\n</Space>\n</Container>",
      "mobile": null
    },
    {
      "title": "Атрибуты",
      "description": "У компонента есть два состояния — в процессе заполнения и полностью заполненный.\nМожно задать направление заполнения, цвет прогрессбара, наличие желоба и контент для обоих состояний.",
      "desktop": "<Container align={isMobile() ? 'center' : 'left'}>\n<Space direction='horizontal'>\n<CircularProgressBar\nvalue={0}\ntitle='0%'\nsize={80}\nsubtitle='Caption'\ncontentColor='primary'\n/>\n<CircularProgressBar\nvalue={50}\ntitle='50%'\nsize={80}\nsubtitle='Caption'\ncontentColor='primary'\n/>\n<CircularProgressBar\nvalue={100}\nsize={80}\nicon={CheckmarkMIcon}\ncontentColor='tertiary'\ncompleteIconColor='positive'\n/>\n</Space>\n<Gap size={16} />\n<Space direction='horizontal'>\n<CircularProgressBar value={0} size={80} icon={CheckmarkMIcon} contentColor='tertiary' />\n<CircularProgressBar value={50} size={80} icon={CheckmarkMIcon} contentColor='tertiary' />\n<CircularProgressBar\nvalue={100}\nsize={80}\nicon={CheckmarkMIcon}\ncontentColor='tertiary'\ncompleteIconColor='primary-inverted'\nfillComplete={true}\n/>\n</Space>\n<Gap size={16} />\n<Space direction='horizontal'>\n<CircularProgressBar value={0} title='0%' size={80} contentColor='primary' />\n<CircularProgressBar\nvalue={50}\ntitle='50%'\nsize={80}\nview='negative'\ncontentColor='primary'\n/>\n<CircularProgressBar\nvalue={100}\nsize={80}\ntitleComplete='100%'\nview='negative'\ncompleteTextColor='negative'\n/>\n</Space>\n</Container>",
      "mobile": null
    },
    {
      "title": "Таймер",
      "description": "Компонент можно превратить в таймер, передав соответствующие параметры.",
      "desktop": "<Container align={isMobile() ? 'center' : 'left'}>\n<Space direction='horizontal'>\n<CircularProgressBar\nvalue={{ timer: 60 }}\nsize={80}\ndirectionType='desc'\ncontentColor='primary'\n/>\n<CircularProgressBar\nvalue={{ timer: 60, counting: 'forward' }}\nsize={80}\ndirectionType='asc'\ncontentColor='primary'\n/>\n</Space>\n<Gap size={16} />\n<Space direction='horizontal'>\n<CircularProgressBar\nvalue={{ timer: 60, counting: 'forward' }}\nsize={80}\ndirectionType='desc'\ncontentColor='primary'\n/>\n<CircularProgressBar\nvalue={{ timer: 60 }}\nsize={80}\ndirectionType='asc'\ncontentColor='primary'\n/>\n</Space>\n</Container>",
      "mobile": null
    }
  ]
